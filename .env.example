# ═══════════════════════════════════════════════════════════════════════════
#  AlMossah — متغيرات البيئة
#  انسخ هذا الملف إلى .env وعدّل القيم
#  لا ترفع ملف .env على GitHub أبداً!
# ═══════════════════════════════════════════════════════════════════════════

# ─── البيئة ───────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── قاعدة البيانات PostgreSQL ───────────────────────────────────────────
# صيغة: postgres://المستخدم:كلمة_المرور@الخادم:المنفذ/اسم_القاعدة
DATABASE_URL=postgres://almossah:CHANGE_ME_DB_PASSWORD@localhost:5432/almossah

# ─── أمان (أنشئ بـ: openssl rand -hex 32) ───────────────────────────────
# مشترك بين API Server والـ Worker — يجب أن يكون متطابقاً في كليهما
WORKER_SECRET=CHANGE_ME_32_CHARS_RANDOM

# مفتاح JWT — لتوقيع جلسات تسجيل الدخول
SESSION_SECRET=CHANGE_ME_64_CHARS_RANDOM

# ─── إعدادات الإرسال ─────────────────────────────────────────────────────
# Timezone لساعات العمل (الأرقام المطابقة لمنطقتك):
#   السعودية/الكويت/البحرين/قطر: Asia/Riyadh
#   الإمارات/عُمان:              Asia/Dubai
#   مصر:                         Africa/Cairo
#   العراق:                       Asia/Baghdad
#   الأردن/لبنان/فلسطين:         Asia/Beirut
SEND_TIMEZONE=Asia/Riyadh

# إجبار proxy لكل حساب (true = لا يمكن إضافة حساب بدون proxy)
REQUIRE_PROXY=true

# Origins المسموح بها للـ frontend (افصل بفواصل إذا كان أكثر من domain)
CORS_ORIGIN=https://your-domain.com

# ─── المنافذ ─────────────────────────────────────────────────────────────
PORT=8080
WA_WORKER_PORT=8088

# عنوان API Server من منظور الـ Worker
API_SERVER_URL=http://localhost:8080

# ─── المتصفح Chromium ────────────────────────────────────────────────────
# Ubuntu/Debian: /usr/bin/chromium-browser
# CentOS/RHEL:   /usr/bin/chromium
# اتركه فارغاً للاكتشاف التلقائي
CHROMIUM_PATH=/usr/bin/chromium-browser
