modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "WA Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AlMossah Dashboard"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 8080/tcp 2>/dev/null; sleep 1; PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "WA Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/wa-worker && node src/index.js"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "AlMossah Dashboard"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=18130 BASE_PATH=/ pnpm --filter @workspace/frontend run dev"
waitForPort = 18130

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

# ── Environment variables ──────────────────────────────────────────────────
# SECURITY: All secrets MUST be set via Replit Secrets panel (or OS env vars).
# Do NOT put credentials in this file.
#
# Required secrets:
#   JWT_SECRET          — random 64-char hex (openssl rand -hex 32)
#   ADMIN_USERNAME      — dashboard admin username
#   ADMIN_PASSWORD      — strong password (min 16 chars)
#   WORKER_SECRET       — shared secret between API server and WA Worker
#   DATABASE_URL        — PostgreSQL connection string
#
# Non-secret config only:
[userenv]

[userenv.shared]
WORKER_URL = "http://localhost:8088"

[nix]
channel = "stable-25_05"
