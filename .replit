modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "WA Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AlMossah Dashboard"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 8080/tcp 2>/dev/null; sleep 1; PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "WA Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/wa-worker && node src/index.js"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "AlMossah Dashboard"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=18130 BASE_PATH=/ pnpm --filter @workspace/frontend run dev"
waitForPort = 18130

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
JWT_SECRET = "464de744c47cdc665a413c95760a91f723ef495f696068d9a080420d6dd941e77a6bbf533a05474a799d8ebc3b5dbe04"
ADMIN_USERNAME = "admin"
ADMIN_PASSWORD = "AlMossah@2025!"
WORKER_URL = "http://localhost:8088"
